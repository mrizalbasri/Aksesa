# Azure Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

AZURE_ML_ENDPOINT=your_azure_ml_endpoint
AZURE_ML_KEY=your_azure_ml_key

AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=your_document_intelligence_key

AZURE_STORAGE_CONNECTION_STRING=your_storage_connection_string
AZURE_STORAGE_CONTAINER=documents

AZURE_SQL_SERVER=your_server.database.windows.net
AZURE_SQL_DATABASE=Aksesa_db
AZURE_SQL_USER=admin
AZURE_SQL_PASSWORD=your_password

# Google Sign-In (optional — same Client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID on frontend)
GOOGLE_CLIENT_ID=

# Application
DEBUG=true
SECRET_KEY=your_secret_key_for_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEMO_USER_EMAIL=demo@aksesa.id
DEMO_USER_PASSWORD=Aksesa123!
DEMO_USER_NAME=Demo UMKM

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
